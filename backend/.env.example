# --- Application Framework ---
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# --- Database ---
MONGO_URI=mongodb://localhost:27017/job_portal_db

# --- Security & JWT ---
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=1d

# --- Initial Admin Setup ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_password

# --- Cloudinary (Image & CV Uploads) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Email/SMTP (OTP Verification) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# --- notify.lk (SMS Notifications) ---
NOTIFY_LK_USER_ID=your_notify_lk_user_id
NOTIFY_LK_API_KEY=your_notify_lk_api_key
NOTIFY_LK_SENDER_ID=NotifyDEMO

# --- Google Integrations ---
GOOGLE_CLIENT_ID=your_google_client_id
RECAPTCHA_SECRET=your_recaptcha_secret_key
